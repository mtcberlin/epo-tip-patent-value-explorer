# ============================================================
# Patent Value Explorer - Environment Variables
# ============================================================
# This is the only required environment variable.
# The Anthropic API key is configured via the in-app Settings dialog.

# ---- PATSTAT MCP Server ----
# URL for the PATSTAT MCP server (patent data lookup via BigQuery)
# API key is included as query parameter
PATSTAT_MCP_URL=https://patstat.depa.tech/mcp?api_key=your-api-key
